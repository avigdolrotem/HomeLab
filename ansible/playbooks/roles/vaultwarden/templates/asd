version: '3'
services:
  vaultwarden:
    image: vaultwarden/server:latest
    container_name: vaultwarden
    restart: unless-stopped
    environment:
      DATABASE_URL: "mysql://{{ vaultwarden_db_user }}:{{ vaultwarden_db_pass }}@{{ vaultwarden_db_host }}/{{ vaultwarden_db_name }}"
      # You can add ADMIN_TOKEN and other envs here
    volumes:
      - ./vw-data:/data
    ports:
      - "80:80"
